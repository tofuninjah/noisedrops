---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import VideoCard from '../../components/VideoCard.astro';
import { getPlaylists, getPlaylist } from '../../lib/youtube';

export async function getStaticPaths() {
  const playlists = await getPlaylists();
  return playlists.map((pl) => ({
    params: { playlistId: pl.id },
  }));
}

const { playlistId } = Astro.params;
const playlist = await getPlaylist(playlistId);

if (!playlist) {
  return Astro.redirect('/rooms');
}

const description = playlist.description
  ? playlist.description.slice(0, 160) + (playlist.description.length > 160 ? '…' : '')
  : `Long-form ambient videos in the ${playlist.title} room on Noisedrops.`;

const truncatedDesc =
  playlist.description && playlist.description.length > 300
    ? playlist.description.slice(0, 300) + '…'
    : playlist.description;
---

<BaseLayout
  title={`${playlist.title} — Noisedrops`}
  description={description}
  ogImage={playlist.thumbnailUrl}
>
  <section class="py-16">
    <Container>
      <!-- Back link -->
      <a href="/rooms" class="inline-flex items-center gap-1.5 text-sm text-ink-faint hover:text-ink-muted transition-colors mb-10">
        ← All Rooms
      </a>

      <!-- Playlist header -->
      <div class="mb-10">
        <h1 class="text-3xl font-semibold text-ink">{playlist.title}</h1>
        {
          truncatedDesc && (
            <p class="mt-4 text-ink-muted leading-relaxed max-w-2xl">{truncatedDesc}</p>
          )
        }
        <p class="mt-3 text-sm text-ink-faint">
          {playlist.longFormCount} long-form video{playlist.longFormCount !== 1 ? 's' : ''}
        </p>
      </div>

      <!-- Video grid -->
      {
        playlist.videos.length === 0 ? (
          <p class="text-ink-faint text-sm">No long-form videos in this room yet.</p>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {playlist.videos.map((v) => (
              <VideoCard video={v} />
            ))}
          </div>
        )
      }
    </Container>
  </section>
</BaseLayout>
