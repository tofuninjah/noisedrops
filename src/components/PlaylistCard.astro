---
import type { NDPlaylist } from '../lib/youtube';
import { formatDate } from '../lib/format';

interface Props {
  playlist: NDPlaylist;
}

const { playlist } = Astro.props;
const updatedLabel = playlist.updatedAt ? formatDate(playlist.updatedAt) : null;
const excerpt = playlist.description
  ? playlist.description.slice(0, 120) + (playlist.description.length > 120 ? '…' : '')
  : null;
---

<a
  href={`/rooms/${playlist.id}`}
  class="group block bg-surface-subtle border border-surface-muted rounded-2xl overflow-hidden hover:border-accent/40 transition-colors"
>
  {
    playlist.thumbnailUrl && (
      <div class="aspect-video overflow-hidden">
        <img
          src={playlist.thumbnailUrl}
          alt={playlist.title}
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
        />
      </div>
    )
  }
  <div class="p-5">
    <h2 class="font-medium text-ink group-hover:text-accent transition-colors leading-snug">
      {playlist.title}
    </h2>
    {excerpt && <p class="mt-1.5 text-sm text-ink-muted line-clamp-2">{excerpt}</p>}
    <div class="mt-3 flex items-center gap-3 text-xs text-ink-faint">
      <span>{playlist.longFormCount} video{playlist.longFormCount !== 1 ? 's' : ''}</span>
      {updatedLabel && <span>· Updated {updatedLabel}</span>}
    </div>
  </div>
</a>
